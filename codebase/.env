# =============================================================================
# CV GENERATOR — Configuration OAuth
# =============================================================================
# Ce fichier est versionné : il ne contient que des IDs Drive, pas de secret.
# Le secret OAuth vit uniquement dans client_secret.json (récupéré depuis
# LastPass, jamais committé — voir .gitignore).

# ── Client OAuth "application de bureau" ──────────────────────────────────────
# Créé une seule fois dans Google Cloud (voir SETUP-OAUTH.md à la racine).
# Ce fichier IDENTIFIE l'application ; il n'ouvre aucune donnée par lui-même.
# L'accès réel dépend du compte Google de l'utilisateur + des partages Drive.
GOOGLE_OAUTH_CLIENT_SECRET_FILE=./client_secret.json

# Où stocker le token utilisateur (optionnel).
# Défaut : ~/.config/cv-c2c/token-cv-generator.json
# GOOGLE_OAUTH_TOKEN_FILE=./token-cv-generator.json

# ── Dossiers Drive ────────────────────────────────────────────────────────────
# ID du dossier racine Drive (contient collaborateurs/, aos/, assets/, etc.)
GOOGLE_DRIVE_FOLDER_ID=19KcvBp0BfhwuSz_x5iEyV8SVR1VcVTd4

# ID du sous-dossier collaborateurs (optionnel — auto-détecté si absent)
COLLABORATEURS_FOLDER_ID=1Y8zd-ZZnWmMBrRLQMva4k_uzF_Y05k-q

# ID du fichier competences.yaml sur Drive (optionnel — auto-détecté si absent)
COMPETENCES_FILE_ID=1NbuGyNCz4Se0Y3zWIU7JlUDZxEb0sP5Z

# ── Mode local (développement sans Drive) ─────────────────────────────────────
# Si AUCUN client OAuth n'est configuré ci-dessus, l'app bascule en mode local
# et lit les fiches YAML depuis ../collaborateurs/ (ou COLLABORATEURS_LOCAL_DIR).
# COLLABORATEURS_LOCAL_DIR=/chemin/vers/collaborateurs

# Admin (fallback si pas de _app-config.yaml sur le Drive)
ADMINS=pierre.grambert@camptocamp.com
