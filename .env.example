# =============================================================================
# CV GENERATOR — Configuration (copier en .env et renseigner les valeurs)
# =============================================================================
# Les valeurs sont stockées dans LastPass (vault Camptocamp / cv-generator).

# ── Credentials Google Drive (lecture seule) ──────────────────────────────────
# Coller le contenu JSON du service account SUR UNE SEULE LIGNE
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ID du dossier racine Drive (contient collaborateurs/, aos/, assets/, etc.)
GOOGLE_DRIVE_FOLDER_ID=1aBcDeFgHiJkLmNoPqRsTuV

# ID du sous-dossier collaborateurs (optionnel — auto-détecté si absent)
# COLLABORATEURS_FOLDER_ID=1aBcDeFgHiJkLmNoPqRsTuV

# ID du fichier competences.yaml sur Drive (optionnel — auto-détecté si absent)
# COMPETENCES_FILE_ID=1wXIAfrHkiLIBjttcwHCWcJswXldJmRNf

# ── Ingestion fiche fin de projet (écriture Drive) ────────────────────────────
# Credentials du SA cv-editor (scope write) — même valeur que cv-editor/.env
# Utiliser CV_EDITOR_SA_FILE (chemin fichier JSON) OU CV_EDITOR_SA_JSON (inline)
CV_EDITOR_SA_FILE=/chemin/vers/cv-editor-sa.json
# CV_EDITOR_SA_JSON={"type":"service_account",...}

# ── Mode local (développement sans Drive) ─────────────────────────────────────
# Pointer vers un dossier local contenant les fiches YAML collaborateurs.
# Si cette variable est absente ET qu'aucun credential Google n'est défini,
# l'app cherche automatiquement ../collaborateurs/ (relatif à son répertoire).
# COLLABORATEURS_LOCAL_DIR=/chemin/vers/collaborateurs
