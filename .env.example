# =============================================================================
# C2C TENDERS APP — Configuration OAuth
# =============================================================================
# Ce fichier est versionné : il ne contient que des IDs Drive, pas de secret.
# Le secret OAuth vit uniquement dans client_secret.json (récupéré depuis
# LastPass, jamais committé — voir .gitignore).

# ── Client OAuth "application de bureau" ──────────────────────────────────────
# Créé une seule fois dans Google Cloud (voir SETUP-OAUTH.md).
# Ce fichier IDENTIFIE l'application ; il n'ouvre aucune donnée par lui-même.
# L'accès réel dépend du compte Google de l'utilisateur + des partages Drive.
GOOGLE_OAUTH_CLIENT_SECRET_FILE=./client_secret.json

# Où stocker le token utilisateur (optionnel).
# Défaut : ~/.config/cv-c2c/token-c2c-tenders-app.json
# GOOGLE_OAUTH_TOKEN_FILE=./token-c2c-tenders-app.json

# ── Dossiers Drive ────────────────────────────────────────────────────────────
# ID du dossier racine Drive (contient collaborateurs/, _competences.yaml, etc.)
# Récupère l'ID dans l'URL du dossier Drive : .../folders/<ID>
GOOGLE_DRIVE_FOLDER_ID=remplace-par-l-id-du-dossier-drive-racine

# ID du sous-dossier collaborateurs (optionnel — auto-détecté si absent)
# COLLABORATEURS_FOLDER_ID=

# ID du fichier _competences.yaml sur Drive (optionnel — auto-détecté si absent)
# COMPETENCES_FILE_ID=

# ID du fichier _clients.yaml sur Drive (optionnel — auto-détecté si absent)
# CLIENTS_FILE_ID=

# ── Rôle admin & notifications (fallback) ─────────────────────────────────────
# Source de vérité recommandée : le fichier `_app-config.yaml` sur le Drive
# (voir _app-config.example.yaml). Ces variables ne servent que de repli si ce
# fichier est absent. Emails séparés par des virgules.
# ADMINS=prenom.nom@camptocamp.com
# NOTIFY_RECIPIENTS=cv-admins@camptocamp.com
